{
  "name": "arxiv-toolkit",
  "version": "0.1.3",
  "description": "Search arXiv, fetch metadata, and read papers (HTML→Markdown with PDF fallback) — CLI and MCP server.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Ali Ildan",
    "email": "ali.ildan@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aliildan/arxiv-toolkit"
  },
  "homepage": "https://github.com/aliildan/arxiv-toolkit#readme",
  "bugs": {
    "url": "https://github.com/aliildan/arxiv-toolkit/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.18 || >=24.11"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "arxiv": "./dist/cli.js",
    "arxiv-mcp": "./dist/mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "arxiv",
    "arXiv",
    "papers",
    "research",
    "mcp",
    "model-context-protocol",
    "cli",
    "markdown",
    "bibtex"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:live": "ARXIV_LIVE=1 vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "tsdown",
    "prepublishOnly": "tsc --noEmit && vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "env-paths": "^4.0.0",
    "fast-xml-parser": "^5.9.3",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.2",
    "zod": "^3.25"
  },
  "peerDependencies": {
    "playwright-core": "*"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/turndown": "*",
    "tsdown": "^0.22.3",
    "typescript": "^6.0",
    "vitest": "^4.1.9"
  }
}
